# Portable default mapping for harness roots.
#
# Copy this file to the ignored, machine-local install.conf and customize that
# copy for the harnesses installed on the current machine.
#
#   claude  ~/.claude/skills
#   codex   ~/.codex/skills
#   agents  ~/.agents/skills   (harness-neutral root)
#   none    installed nowhere; the skill lives here but no harness loads it
#
# Every skill directory in this repo must appear below. An unlisted skill is an
# error, not a default: leaving "where does this go?" implicit is how the harness
# roots drifted apart in the first place.
#
# install.sh reads install.conf, links its listed roots, and *removes* the
# unlisted ones. Keep this sample complete so a fresh local copy is valid.

accessibility-testing   claude
braindump-intake        claude codex agents
fable-workflow-checklist claude
gh-issues               claude
gh-pr-review-comments   claude codex
git-gtr-worktrees       claude codex agents
obsidian-personal       claude codex agents
plan-mode-tdd           none
pytest-profiling        claude codex agents
retro                   claude codex agents
s3-troubleshooting      claude codex
session-inspect         claude codex agents
